<h1>Artists</h1>

{{! READ table }}
<table>
    <thead>
        {{! For the table header row, we print the DB attribute names }}
        <tr>
            {{#each artists.[0]}}
            <th>
                {{@key}}
            </th>
            {{/each}}
        </tr>
    </thead>

    <tbody>
        {{! For each row, print the artist attributes }}
        {{#each artists}}
        <tr>
            <td>{{this.id_artist}}</td>
            <td>{{this.first_name}}</td>
            <td>{{this.last_name}}</td>
            <td>{{this.email}}</td>
            <td>{{this.phone}}</td>
        </tr>
        {{/each}}
    </tbody>
</table>

<div class="gridForm">
    {{! CREATE form }}
    <form class='cuForm' id='create_artist_form' method='POST' action='/artists/create'>
        <h2>Create an Artist</h2>

        <label for='create_artist_first_name'>First Name: </label>
        <input type='text' name='create_artist_first_name' id='create_artist_first_name' required />

        <label for='create_artist_last_name'>Last Name: </label>
        <input type='text' name='create_artist_last_name' id='create_artist_last_name' required />

        <label for='create_artist_email'>Email: </label>
        <input type='email' name='create_artist_email' id='create_artist_email' required />

        <label for='create_artist_phone'>Phone: </label>
        <input type='text' name='create_artist_phone' id='create_artist_phone' />

        <input type='submit' class="submit"/>
    </form>

    {{! UPDATE form }}
    <form class='cuForm' id='update_artist_form' method='POST' action='/artists/update'>
        <h2>Update an Artist</h2>

        <label for='update_artist_id'>Artist to Update: </label>
        <select name='update_artist_id' id='update_artist_id' required>
            <option value='' disabled selected>Select an Artist</option>
            {{#each artists}}
            <option value='{{this.id_artist}}' required>
                {{this.id_artist}}
                -
                {{this.first_name}}
                {{this.last_name}}
            </option>
            {{/each}}
        </select>

        <label for='update_artist_email'>Email: </label>
        <input type='email' name='update_artist_email' id='update_artist_email' required />

        <label for='update_artist_phone'>Phone: </label>
        <input type='text' name='update_artist_phone' id='update_artist_phone' />

        <input type='submit' class="submit"/>
    </form>

    {{! DELETE form }}
    <form class='cuForm' id='delete_artist_form' method='POST' action='/artists/delete'>
        <h2>Delete an Artist</h2>

        <label for='delete_artist_id'>Artist to Delete: </label>
        <select name='delete_artist_id' id='delete_artist_id' required>
            <option value='' disabled selected>Select an Artist</option>
            {{#each artists}}
            <option value='{{this.id_artist}}' required>
                {{this.id_artist}}
                -
                {{this.first_name}}
                {{this.last_name}}
            </option>
            {{/each}}
        </select>

        <input type='submit' class="submit"/>
    </form>
</div>

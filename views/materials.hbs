<h1>Materials</h1>

{{! READ table }}
<table>
    <thead>
        {{! For the table header row, we print the DB attribute names }}
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Description</th>
            <th>Created On</th>
            <th>Modified On</th>
            <th>Base Color</th>
            <th>Roughness</th>
            <th>Metallic</th>
            <th>Transparency</th>
            <th>File Path</th>
            <th>Artist</th>
            <th>Active</th>
        </tr>
    </thead>

    <tbody>
        {{! For each row, print the material attributes }}
        {{#each materials}}
        <tr>
            <td>{{this.ID}}</td>
            <td>{{this.Name}}</td>
            <td>{{this.Description}}</td>
            <td>{{this.[Created On]}}</td>
            <td>{{this.[Modified On]}}</td>
            <td>{{this.[Base Color]}}</td>
            <td>{{this.Roughness}}</td>
            <td>{{this.Metallic}}</td>
            <td>{{this.Transparency}}</td>
            <td>{{this.[File Path]}}</td>
            <td>{{this.Artist}}</td>
            <td>{{#if this.Active}}YES{{else}}NO{{/if}}</td>
        </tr>
        {{/each}}
    </tbody>
</table>

<div class="gridForm">
    {{! CREATE form }}
    
    <form class='cuForm' id='create_material_form' method='POST' action='/materials/create'>
        <h2>Create a Material</h2>

        <label for='create_material_name'>Name: </label>
        <input type='text' name='create_material_name' id='create_material_name' required />

        <label for='create_material_description'>Description: </label>
        <input type='text' name='create_material_description' id='create_material_description' />

        <label for='create_material_created_date'>Created Date: </label>
        <input type='date' name='create_material_created_date' id='create_material_created_date' required />

        <label for='create_material_modified_date'>Modified Date: </label>
        <input type='date' name='create_material_modified_date' id='create_material_modified_date' />

        <label for='create_material_base_color'>Base Color: </label>
        <input type='text' name='create_material_base_color' id='create_material_base_color' />

        <label for='create_material_roughness'>Roughness: </label>
        <input type='number' name='create_material_roughness' id='create_material_roughness' step='0.01' min='0' max='1' />

        <label for='create_material_metallic'>Metallic: </label>
        <input type='number' name='create_material_metallic' id='create_material_metallic' step='0.01' min='0' max='1' />

        <label for='create_material_transparency'>Transparency: </label>
        <input type='number' name='create_material_transparency' id='create_material_transparency' step='0.01' min='0' max='1' />

        <label for='create_material_file_path'>File Path: </label>
        <input type='text' name='create_material_file_path' id='create_material_file_path' required />

        <label for='create_material_id_artist'>Artist ID: </label>
        <select name='create_material_id_artist' id='create_material_id_artist'>
            <option value='' disabled selected>Select an Artist</option>
            {{#each artists}}
            <option value='{{this.id_artist}}'>
                {{this.id_artist}} - {{this.first_name}} {{this.last_name}}
            </option>
            {{/each}}
        </select>

        <label for='create_material_is_active'>Is Active: </label>
        <select name='create_material_is_active' id='create_material_is_active' required >
            <option value='' selected>Select</option>
            <option value='1'>Active</option>
            <option value='0'>Inactive</option>
        </select>

        <input type='submit' class="submit"/>
    </form>

    {{! UPDATE form }}
    <form class='cuForm' id='update_material_form' method='POST' action='/materials/update'>
        <h2>Update a Material</h2>

        <label for='update_material_id'>Material to Update: </label>
        <select name='update_material_id' id='update_material_id' required>
            <option value='' disabled selected>Select a Material</option>
            {{#each materials}}
            <option value="{{this.ID}}"
                data-description="{{this.Description}}" 
                data-modified-date="{{this.[Modified On]}}"
                data-base-color="{{this.[Base Color]}}"
                data-roughness="{{this.Roughness}}"
                data-metallic="{{this.Metallic}}"
                data-transparency="{{this.Transparency}}"
                data-file-path="{{this.[File Path]}}"
                data-artist="{{this.ArtistID}}"
                data-active="{{this.Active}}">
                {{this.ID}} - {{this.Name}}
            </option>
            {{/each}}
        </select>

        <label for='update_material_description'>Description: </label>
        <input type='text' name='update_material_description' id='update_material_description' />

        <label for='update_material_modified_date'>Modified Date: </label>
        <input type='date' name='update_material_modified_date' id='update_material_modified_date' />

        <label for='update_material_base_color'>Base Color: </label>
        <input type='text' name='update_material_base_color' id='update_material_base_color' />

        <label for='update_material_roughness'>Roughness: </label>
        <input type='number' name='update_material_roughness' id='update_material_roughness' step='0.01' min='0' max='1' />

        <label for='update_material_metallic'>Metallic: </label>
        <input type='number' name='update_material_metallic' id='update_material_metallic' step='0.01' min='0' max='1' />

        <label for='update_material_transparency'>Transparency: </label>
        <input type='number' name='update_material_transparency' id='update_material_transparency' step='0.01' min='0' max='1' />

        <label for='update_material_file_path'>File Path: </label>
        <input type='text' name='update_material_file_path' id='update_material_file_path' required />

        <label for='update_material_id_artist'>Artist ID: </label>
        <select name='update_material_id_artist' id='update_material_id_artist'>
            <option value='' disabled selected>Select an Artist</option>
            {{#each artists}}
            <option value='{{this.id_artist}}'>
                {{this.id_artist}} - {{this.first_name}} {{this.last_name}}
            </option>
            {{/each}}
        </select>

        <label for='update_material_is_active'>Is Active: </label>
        <select name='update_material_is_active' id='update_material_is_active' required >
            <option value='' disabled selected>Select</option>
            <option value='1'>Active</option>
            <option value='0'>Inactive</option>
        </select>

        <input type='submit' class="submit"/>
    </form>

    {{! DELETE form }}
    <form class='cuForm' id='delete_material_form' method='POST' action='/materials/delete'>
        <h2>Delete a Material</h2>

        <label for='delete_material_id'>Material to Delete: </label>
        <select name='delete_material_id' id='delete_material_id' required>
            <option value='' disabled selected>Select a Material</option>
            {{#each materials}}
            <option value='{{this.ID}}' required>
                {{this.ID}}
                -
                {{this.Name}}
            </option>
            {{/each}}
        </select>

        <input type='submit' class="submit"/>
    </form>
</div>

{{!-- Auto Populate --}}
<script>
    const materialSelect = document.getElementById('update_material_id');
    const descriptionInput = document.getElementById('update_material_description');
    const modifiedDateInput = document.getElementById('update_material_modified_date');
    const baseColorInput = document.getElementById('update_material_base_color');
    const roughnessInput = document.getElementById('update_material_roughness');
    const metallicInput = document.getElementById('update_material_metallic');
    const transparencyInput = document.getElementById('update_material_transparency');
    const filePathInput = document.getElementById('update_material_file_path');
    const artistInput = document.getElementById('update_material_id_artist');
    const activeInput = document.getElementById('update_material_is_active');

    materialSelect.addEventListener('change', function() {
        // Get the currently selected option element
        const selectedOption = this.options[this.selectedIndex];

        // Pull the data attributes we added in Step 1
        const description = selectedOption.getAttribute('data-description');
        const modifiedDate = selectedOption.getAttribute('data-modified-date');
        const baseColor = selectedOption.getAttribute('data-base-color');
        const roughness = selectedOption.getAttribute('data-roughness');
        const metallic = selectedOption.getAttribute('data-metallic');
        const transparency = selectedOption.getAttribute('data-transparency');
        const filePath = selectedOption.getAttribute('data-file-path');
        const artist = selectedOption.getAttribute('data-artist');
        const active = selectedOption.getAttribute('data-active');

        const mdParts = modifiedDate.split('/');
        const mdFormatted = `${mdParts[2]}-${mdParts[1]}-${mdParts[0]}`; 

        // Populate the input fields
        descriptionInput.value = description || '';
        modifiedDateInput.value = mdFormatted || '';
        baseColorInput.value = baseColor || '';
        roughnessInput.value = roughness || '';
        metallicInput.value = metallic || '';
        transparencyInput.value = transparency || '';
        filePathInput.value = filePath || '';
        artistInput.value = artist || '';
        activeInput.value = active || '';
    });
</script>